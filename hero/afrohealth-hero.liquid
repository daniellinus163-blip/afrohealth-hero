{% comment %}
  AfroHealth — Vibrant glass hero (Shopify OS 2.0)
  Upload afrohealth-hero.css & afrohealth-hero.js to Assets.
{% endcomment %}

{{ 'afrohealth-hero.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- assign bg_url = section.settings.background_image | image_url: width: 2400 -%}
{%- assign poster_url = section.settings.background_image | image_url: width: 1600 -%}

{% if section.settings.background_image != blank %}
  <style>
    #afh-hero-{{ section.id }} .afh-hero__image {
      background-image: url("{{ bg_url | escape }}");
    }
  </style>
{% endif %}

<section
  id="afh-hero-{{ section.id }}"
  class="afh-hero"
  aria-label="{{ section.settings.heading_line_1 | escape }}"
>
  {%- assign afh_urls_trim = section.settings.video_urls | strip -%}
  {%- assign afh_has_video = false -%}
  {%- if section.settings.video_url != blank or afh_urls_trim != '' -%}
    {%- assign afh_has_video = true -%}
  {%- endif -%}

  <script type="application/json" class="afh-hero__video-config">
    [
      {%- assign first_vid = true -%}
      {%- if section.settings.video_urls != blank -%}
        {%- assign parts = section.settings.video_urls | split: ',' -%}
        {%- for p in parts -%}
          {%- assign u = p | strip -%}
          {%- if u != '' -%}
            {%- unless first_vid -%},{%- endunless -%}
            "{{ u | escape }}"
            {%- assign first_vid = false -%}
          {%- endif -%}
        {%- endfor -%}
      {%- elsif section.settings.video_url != blank -%}
        "{{ section.settings.video_url | escape }}"
      {%- endif -%}
    ]
  </script>

  <div class="afh-hero__media">
    <div class="afh-hero__image" role="img" aria-hidden="true"></div>
    {% if afh_has_video %}
    <div class="afh-hero__video-wrap" aria-hidden="true">
      <div class="afh-hero__video-layer is-active">
        <video
          class="afh-hero__video"
          muted
          loop
          playsinline
          preload="metadata"
          {% if section.settings.background_image != blank %}poster="{{ poster_url | escape }}"{% endif %}
        ></video>
      </div>
      <div class="afh-hero__video-layer">
        <video
          class="afh-hero__video"
          muted
          loop
          playsinline
          preload="none"
          {% if section.settings.background_image != blank %}poster="{{ poster_url | escape }}"{% endif %}
        ></video>
      </div>
    </div>
    {% endif %}
    <div class="afh-hero__scrim" aria-hidden="true"></div>
    <div class="afh-hero__vignette" aria-hidden="true"></div>
    <div class="afh-hero__grain" aria-hidden="true"></div>
  </div>

  <div class="afh-hero__inner">
    <div class="afh-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="afh-hero__eyebrow" data-afh-animate="1">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      <h1 class="afh-hero__headline" data-afh-animate="2">
        {{ section.settings.heading_line_1 | escape }}<br>
        {{ section.settings.heading_line_2_prefix | escape }}
        {% if section.settings.heading_accent != blank %}
          <span class="afh-hero__accent">{{ section.settings.heading_accent | escape }}</span>
        {% endif %}
      </h1>

      {% if section.settings.subheading != blank %}
        <p class="afh-hero__sub" data-afh-animate="3">{{ section.settings.subheading | escape }}</p>
      {% endif %}

      <div class="afh-hero__trust" data-afh-animate="4">
        <div class="afh-hero__trust-row">
          <span class="afh-hero__stars" aria-label="{{ section.settings.reviews_rating_label | escape }}">★★★★★</span>
          <span class="afh-hero__trust-text">{{ section.settings.reviews_text | escape }}</span>
        </div>
        <span class="afh-hero__trust-sep" aria-hidden="true"></span>
        <span class="afh-hero__trust-pill">{{ section.settings.trust_pill_1 | escape }}</span>
        <span class="afh-hero__trust-sep" aria-hidden="true"></span>
        <span class="afh-hero__trust-pill">{{ section.settings.trust_pill_2 | escape }}</span>
      </div>

      {% if section.settings.cta_label != blank %}
        <a class="afh-hero__cta" href="{{ section.settings.cta_link }}" data-afh-animate="5">
          {{ section.settings.cta_label | escape }}
          <span class="afh-hero__cta-icon" aria-hidden="true">→</span>
        </a>
      {% endif %}
    </div>
  </div>
</section>

<script src="{{ 'afrohealth-hero.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "AfroHealth hero",
  "tag": "section",
  "class": "section-afrohealth-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Fallback image (poster / no-video)"
    },
    {
      "type": "textarea",
      "id": "video_urls",
      "label": "Background video URLs",
      "info": "Comma-separated MP4 URLs (e.g. from Shopify Files). Rotates with crossfade. Optional if you use a single URL below."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Single background video (MP4 URL)",
      "info": "Used if the list above is empty."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Co-created by leading nutrition experts"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Headline line 1",
      "default": "You've Been Running At 80%."
    },
    {
      "type": "text",
      "id": "heading_line_2_prefix",
      "label": "Headline line 2 (before accent)",
      "default": "Here's "
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Headline accent",
      "default": "The Other 20%."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheadline",
      "default": "A daily greens drink co-created by leading nutrition experts to give you that extra 20% in one daily scoop."
    },
    {
      "type": "text",
      "id": "reviews_rating_label",
      "label": "Star rating (accessibility label)",
      "default": "4.7 out of 5 stars"
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews text",
      "default": "4.7 verified reviews"
    },
    {
      "type": "text",
      "id": "trust_pill_1",
      "label": "Trust pill 1",
      "default": "Melanin-Optimised"
    },
    {
      "type": "text",
      "id": "trust_pill_2",
      "label": "Trust pill 2",
      "default": "Nutritionist-Formulated"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Claim your 20%"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "AfroHealth hero"
    }
  ]
}
{% endschema %}
