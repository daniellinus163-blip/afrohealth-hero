{% comment %}
  AfroHealth — Cinematic photo hero (Ken Burns) + green tips bar. Upload afrohealth-hero.css & afrohealth-hero.js to Assets.
{% endcomment %}

{{ 'afrohealth-hero.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- assign char_src = '' -%}
{%- if section.settings.character_image != blank -%}
  {%- assign char_src = section.settings.character_image | image_url: width: 1200 -%}
{%- endif -%}

<section
  id="afh-hero-{{ section.id }}"
  class="afh-hero"
  aria-label="{{ section.settings.heading_line_1 | escape }}"
>
  <div class="afh-hero__main">
    <div class="afh-hero__bg" aria-hidden="true"></div>

    <div class="afh-hero__inner">
      <div class="afh-hero__layout">
        <div class="afh-hero__content">
          {% if section.settings.eyebrow != blank %}
            <p class="afh-hero__eyebrow" data-afh-animate="1">{{ section.settings.eyebrow | escape }}</p>
          {% endif %}

          <h1 class="afh-hero__headline" data-afh-animate="2">
            {{ section.settings.heading_line_1 | escape }}<br>
            {{ section.settings.heading_line_2_prefix | escape }}
            {% if section.settings.heading_accent != blank %}
              <span class="afh-hero__accent">{{ section.settings.heading_accent | escape }}</span>
            {% endif %}
          </h1>

          {% if section.settings.subheading != blank %}
            <p class="afh-hero__sub" data-afh-animate="3">{{ section.settings.subheading | escape }}</p>
          {% endif %}

          <div class="afh-hero__trust" data-afh-animate="4">
            <div class="afh-hero__trust-row">
              <span class="afh-hero__stars" aria-label="{{ section.settings.reviews_rating_label | escape }}">★★★★★</span>
              <span class="afh-hero__trust-text">{{ section.settings.reviews_text | escape }}</span>
            </div>
            <span class="afh-hero__trust-sep" aria-hidden="true"></span>
            <span class="afh-hero__trust-pill">{{ section.settings.trust_pill_1 | escape }}</span>
            <span class="afh-hero__trust-sep" aria-hidden="true"></span>
            <span class="afh-hero__trust-pill">{{ section.settings.trust_pill_2 | escape }}</span>
          </div>

          {% if section.settings.cta_label != blank %}
            <a class="afh-hero__cta afh-hero__cta--outline" href="{{ section.settings.cta_link }}" data-afh-animate="5">
              {{ section.settings.cta_label | escape }}
              <span class="afh-hero__cta-icon" aria-hidden="true">→</span>
            </a>
          {% endif %}
        </div>

        {% if char_src != '' %}
          <div class="afh-hero__cinema" data-afh-animate="2">
            <div class="afh-hero__cinema-frame">
              <img
                class="afh-hero__character afh-hero__character--motion"
                src="{{ char_src | escape }}"
                alt="{{ section.settings.character_image_alt | escape }}"
                width="960"
                height="1200"
                loading="eager"
                decoding="async"
              >
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="afh-hero__feature-bar" aria-label="{{ section.settings.feature_bar_title | escape }}">
    <div class="afh-hero__feature-inner">
      <div class="afh-hero__feature-copy">
        {% if section.settings.feature_bar_title != blank %}
          <h2 class="afh-hero__feature-title" data-afh-bar="1">{{ section.settings.feature_bar_title | escape }}</h2>
        {% endif %}
        {% if section.settings.feature_bar_text != blank %}
          <p class="afh-hero__feature-text" data-afh-bar="2">{{ section.settings.feature_bar_text | escape }}</p>
        {% endif %}
        {% if section.settings.feature_cta_label != blank %}
          <a class="afh-hero__feature-cta" href="{{ section.settings.feature_cta_link }}" data-afh-bar="3">{{ section.settings.feature_cta_label | escape }}</a>
        {% endif %}
      </div>
      <ul class="afh-hero__feature-grid" role="list">
        <li class="afh-hero__tip" data-afh-bar="4">
          <span class="afh-hero__tip-badge" aria-hidden="true">01</span>
          <span class="afh-hero__tip-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 3C8.5 3 6 5.5 6 9c0 4 3 8 6 12 3-4 6-8 6-12 0-3.5-2.5-6-6-6z" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 9v4M10 7h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          </span>
          <span class="afh-hero__tip-label">{{ section.settings.tip_1_label | escape }}</span>
        </li>
        <li class="afh-hero__tip" data-afh-bar="5">
          <span class="afh-hero__tip-badge" aria-hidden="true">02</span>
          <span class="afh-hero__tip-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M6 21v-2a4 4 0 014-4h4a4 4 0 014 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9 14l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span class="afh-hero__tip-label">{{ section.settings.tip_2_label | escape }}</span>
        </li>
        <li class="afh-hero__tip" data-afh-bar="6">
          <span class="afh-hero__tip-badge" aria-hidden="true">03</span>
          <span class="afh-hero__tip-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="12" cy="13" rx="7" ry="5" stroke="currentColor" stroke-width="1.5"/><path d="M8 10V8a4 4 0 018 0v2" stroke="currentColor" stroke-width="1.5"/><path d="M10 13h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          </span>
          <span class="afh-hero__tip-label">{{ section.settings.tip_3_label | escape }}</span>
        </li>
        <li class="afh-hero__tip" data-afh-bar="7">
          <span class="afh-hero__tip-badge" aria-hidden="true">04</span>
          <span class="afh-hero__tip-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 4v16M8 8h8M8 16h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.2" opacity="0.5"/></svg>
          </span>
          <span class="afh-hero__tip-label">{{ section.settings.tip_4_label | escape }}</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<script src="{{ 'afrohealth-hero.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "AfroHealth hero",
  "tag": "section",
  "class": "section-afrohealth-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "character_image",
      "label": "Hero character image",
      "info": "Full photo; slow pan/zoom keeps woman and background in frame."
    },
    {
      "type": "text",
      "id": "character_image_alt",
      "label": "Character image alt text",
      "default": "Smiling person enjoying a fresh healthy salad in a bright, natural setting."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Co-created by leading nutrition experts"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Headline line 1",
      "default": "You've Been Running At 80%."
    },
    {
      "type": "text",
      "id": "heading_line_2_prefix",
      "label": "Headline line 2 (before accent)",
      "default": "Here's "
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Headline accent",
      "default": "The Other 20%."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheadline",
      "default": "A daily greens drink co-created by leading nutrition experts to give you that extra 20% in one daily scoop."
    },
    {
      "type": "text",
      "id": "reviews_rating_label",
      "label": "Star rating (accessibility label)",
      "default": "4.7 out of 5 stars"
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews text",
      "default": "4.7 verified reviews"
    },
    {
      "type": "text",
      "id": "trust_pill_1",
      "label": "Trust pill 1",
      "default": "Melanin-Optimised"
    },
    {
      "type": "text",
      "id": "trust_pill_2",
      "label": "Trust pill 2",
      "default": "Nutritionist-Formulated"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Claim your 20%"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "header",
      "content": "Green tips bar"
    },
    {
      "type": "text",
      "id": "feature_bar_title",
      "label": "Tips bar title",
      "default": "Nutrition tips"
    },
    {
      "type": "textarea",
      "id": "feature_bar_text",
      "label": "Tips bar text",
      "default": "Small daily habits that pair perfectly with your greens — stay consistent, stay energised."
    },
    {
      "type": "text",
      "id": "feature_cta_label",
      "label": "Tips bar button label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "feature_cta_link",
      "label": "Tips bar button link"
    },
    {
      "type": "text",
      "id": "tip_1_label",
      "label": "Tip 1 label",
      "default": "Healthy diets"
    },
    {
      "type": "text",
      "id": "tip_2_label",
      "label": "Tip 2 label",
      "default": "Exercise daily"
    },
    {
      "type": "text",
      "id": "tip_3_label",
      "label": "Tip 3 label",
      "default": "Eat fresh"
    },
    {
      "type": "text",
      "id": "tip_4_label",
      "label": "Tip 4 label",
      "default": "Diet nutrition"
    }
  ],
  "presets": [
    {
      "name": "AfroHealth hero"
    }
  ]
}
{% endschema %}
