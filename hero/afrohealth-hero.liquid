{% comment %}
  AfroHealth — Dark deep-green hero video, copy over background (no card); light blue accents.
{% endcomment %}

{{ 'afrohealth-hero.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<section
  id="afh-hero-{{ section.id }}"
  class="afh-hero{% if section.settings.hero_video != blank or section.settings.hero_video_url != blank %} afh-hero--video-bg{% endif %}"
  aria-label="{{ section.settings.heading_line_1 | escape }}"
>
  <div class="afh-hero__main">
    {% if section.settings.hero_video != blank or section.settings.hero_video_url != blank %}
      <div
        class="afh-hero__video-bg"
        role="region"
        {% if section.settings.hero_video_aria_label != blank %}
          aria-label="{{ section.settings.hero_video_aria_label | escape }}"
        {% endif %}
      >
        {% if section.settings.hero_video != blank %}
          {{
            section.settings.hero_video
            | video_tag:
              class: 'afh-hero__video afh-hero__video--bg',
              autoplay: true,
              loop: true,
              muted: true,
              controls: false,
              playsinline: true,
              preload: 'auto',
              image_size: '1920x'
          }}
        {% else %}
          <video
            class="afh-hero__video afh-hero__video--bg"
            src="{{ section.settings.hero_video_url | escape }}"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
          ></video>
        {% endif %}
        <div class="afh-hero__video-scrim" aria-hidden="true"></div>
      </div>
    {% else %}
      <div class="afh-hero__bg" aria-hidden="true"></div>
    {% endif %}

    <div class="afh-hero__inner">
      <div class="afh-hero__content">
        {% if section.settings.eyebrow != blank %}
          <p class="afh-hero__eyebrow" data-afh-animate="1">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}

        <h1 class="afh-hero__headline" data-afh-animate="2">
          {{ section.settings.heading_line_1 | escape }}<br>
          {{ section.settings.heading_line_2_prefix | escape }}
          {% if section.settings.heading_accent != blank %}
            <span class="afh-hero__accent">{{ section.settings.heading_accent | escape }}</span>
          {% endif %}
        </h1>

        {% if section.settings.subheading != blank %}
          <p class="afh-hero__sub" data-afh-animate="3">{{ section.settings.subheading | escape }}</p>
        {% endif %}

        <div class="afh-hero__trust" data-afh-animate="4">
          <div class="afh-hero__trust-row">
            <span class="afh-hero__stars" aria-label="{{ section.settings.reviews_rating_label | escape }}">★★★★★</span>
            <span class="afh-hero__trust-text">{{ section.settings.reviews_text | escape }}</span>
          </div>
          <span class="afh-hero__trust-sep" aria-hidden="true"></span>
          <span class="afh-hero__trust-pill">{{ section.settings.trust_pill_1 | escape }}</span>
          <span class="afh-hero__trust-sep" aria-hidden="true"></span>
          <span class="afh-hero__trust-pill afh-hero__trust-pill--blue">{{ section.settings.trust_pill_2 | escape }}</span>
        </div>

        {% if section.settings.cta_label != blank %}
          <a class="afh-hero__cta afh-hero__cta--outline" href="{{ section.settings.cta_link }}" data-afh-animate="5">
            {{ section.settings.cta_label | escape }}
            <span class="afh-hero__cta-icon" aria-hidden="true">→</span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'afrohealth-hero.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "AfroHealth hero",
  "tag": "section",
  "class": "section-afrohealth-hero",
  "settings": [
    {
      "type": "video",
      "id": "hero_video",
      "label": "Hero video (uploaded)",
      "info": "Optional. Full-bleed behind hero text. If empty, the MP4 URL below is used."
    },
    {
      "type": "text",
      "id": "hero_video_url",
      "label": "Hero video MP4 URL",
      "default": "https://cdn.shopify.com/videos/c/o/v/d426147b68ed42cc9c6d5fa700b0eb7d.mp4",
      "info": "Direct link to your looping hero clip."
    },
    {
      "type": "text",
      "id": "hero_video_aria_label",
      "label": "Video description (accessibility)",
      "default": "Afro Health hero: active lifestyles and daily wellness."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Co-created by leading nutrition experts"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Headline line 1",
      "default": "You've Been Running At 80%."
    },
    {
      "type": "text",
      "id": "heading_line_2_prefix",
      "label": "Headline line 2 (before accent)",
      "default": "Here's "
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Headline accent",
      "default": "The Other 20%."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheadline",
      "default": "A daily greens drink co-created by leading nutrition experts to give you that extra 20% in one daily scoop."
    },
    {
      "type": "text",
      "id": "reviews_rating_label",
      "label": "Star rating (accessibility label)",
      "default": "4.7 out of 5 stars"
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews text",
      "default": "4.7 verified reviews"
    },
    {
      "type": "text",
      "id": "trust_pill_1",
      "label": "Trust pill 1",
      "default": "Melanin-Optimised"
    },
    {
      "type": "text",
      "id": "trust_pill_2",
      "label": "Trust pill 2 (blue accent)",
      "default": "Nutritionist-Formulated"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Claim your 20%"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    }
  ],
  "presets": [
    {
      "name": "AfroHealth hero"
    }
  ]
}
{% endschema %}
